
_default:
  just --list

create-worktree repo name:
  git -C {{ repo }}/default worktree add -b {{ name }} ../{{ name }}
  cp -r --update=none .claude/. {{ repo }}/{{ name }}/.claude/
  grep -qxF '.claude/agents/tk/' {{ repo }}/default/.git/info/exclude \
    || printf '%s\n' '.claude/agents/tk/' '.claude/commands/tk/' '.claude/rules/tk-agents.md' \
      >> {{ repo }}/default/.git/info/exclude

remove-worktree repo name:
  git -C {{ repo }}/default worktree remove ../{{ name }}
  git -C {{ repo }}/default branch -d {{ name }}

start-subagent repo worktree ticket-id:
  #!/usr/bin/env bash
  cd "{{ justfile_directory() }}"
  agent=$(tk query 'select(.id | contains("{{ ticket-id }}"))' | jq -r '.assignee')
  prompt=$(sed 's/\$ARGUMENTS\[0\]/{{ ticket-id }}/' .claude/commands/tk/subagent-task.md)
  # TODO: figure out better permission handling for Bash
  cd {{ repo }}/{{ worktree }} && claude \
    --agent "$agent" \
    --allowedTools "Bash,Read,Edit,Write,Grep,Glob" \
    -p "$prompt"
