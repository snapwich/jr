alias deps := worktree-deps

# Show features that depend on a given ticket as a tree
[group("subagent-architect-reviewer")]
feature-deps ticket-id:
  #!/usr/bin/env bash
  cd "${TK_PROJECT_DIR:-{{ justfile_directory() }}}"
  root_id="{{ ticket-id }}"

  # Resolve partial ID
  root_json=$({{ tk }} query "select(.id | contains(\"$root_id\"))" 2>/dev/null | head -1)
  if [[ -z "$root_json" ]]; then
    echo "Ticket not found: $root_id" >&2
    exit 1
  fi
  root_id=$(echo "$root_json" | jq -r '.id')

  # Build children map: dep_id → space-separated dependent feature IDs
  declare -A children

  while IFS= read -r feat_json; do
    [[ -z "$feat_json" ]] && continue
    feat_id=$(echo "$feat_json" | jq -r '.id')
    while IFS= read -r dep_id; do
      [[ -z "$dep_id" ]] && continue
      children["$dep_id"]="${children[$dep_id]:-} $feat_id"
    done < <(echo "$feat_json" | jq -r '.deps[]?' 2>/dev/null)
  done < <({{ tk }} query 'select(.type == "feature")' 2>/dev/null)

  # Recursive tree render
  render() {
    local id="$1" prefix="$2" connector="$3"
    local title
    title=$({{ tk }} show "$id" 2>/dev/null | grep '^# ' | head -1 | sed 's/^# //')
    echo "${prefix}${connector}${id}: ${title}"

    local kids=(${children[$id]:-})
    local count=${#kids[@]}
    local i=0
    local child_prefix="$prefix"
    [[ "$connector" == "├── " ]] && child_prefix="${prefix}│   "
    [[ "$connector" == "└── " ]] && child_prefix="${prefix}    "

    for kid in "${kids[@]}"; do
      ((i++))
      if (( i == count )); then
        render "$kid" "$child_prefix" "└── "
      else
        render "$kid" "$child_prefix" "├── "
      fi
    done
  }

  render "$root_id" "" ""

# Show project layout — repos and their worktrees (mirrors `git worktree list`)
[group("human")]
ls:
  #!/usr/bin/env bash
  cd "${TK_PROJECT_DIR:-{{ justfile_directory() }}}"
  JUSTFILE="{{ justfile() }}"
  WORKING_DIR="${TK_PROJECT_DIR:-{{ justfile_directory() }}}"

  # Build worktree-name → feature-id map
  declare -A wt_to_fid
  while IFS= read -r feat_json; do
    [[ -z "$feat_json" ]] && continue
    feat_id=$(echo "$feat_json" | jq -r '.id')
    wt_name=$(just --justfile "$JUSTFILE" --working-directory "$WORKING_DIR" worktree-name "$feat_id" 2>/dev/null)
    [[ -n "$wt_name" ]] && wt_to_fid["$wt_name"]="$feat_id"
  done < <({{ tk }} query 'select(.type == "feature")' 2>/dev/null)

  render_worktrees() {
    local dir="$1" prefix="$2"
    local entries=()

    # Parse `git worktree list --porcelain` for worktree paths, extract basenames
    if worktree_output=$(git -C "$dir/default" worktree list --porcelain 2>/dev/null); then
      while IFS= read -r line; do
        [[ "$line" == worktree\ * ]] || continue
        local wt_path="${line#worktree }"
        local name
        name=$(basename "$wt_path")
        entries+=("$name")
      done <<< "$worktree_output"
    fi

    # Fallback: if git failed but default/ exists, show at least default
    if [[ ${#entries[@]} -eq 0 && -d "$dir/default" ]]; then
      entries=("default")
    fi

    # Sort: default/ first, then alphabetical
    local sorted=()
    for e in "${entries[@]}"; do
      [[ "$e" == "default" ]] && sorted=("default" "${sorted[@]}") || sorted+=("$e")
    done

    local count=${#sorted[@]}
    local i=0
    for e in "${sorted[@]}"; do
      ((i++))
      local label="${e}/"
      # Append feature ID if this worktree has a matching feature
      if [[ -v "wt_to_fid[$e]" ]]; then
        label="$label  (${wt_to_fid[$e]})"
      fi
      if (( i == count )); then
        echo "${prefix}└── ${label}"
      else
        echo "${prefix}├── ${label}"
      fi
    done
  }

  if [[ -d "default" ]]; then
    # Single-repo mode
    echo "."
    render_worktrees "." ""
  elif compgen -G "*/default" > /dev/null 2>&1; then
    # Multi-repo mode
    echo "."
    repos=()
    for d in */default; do
      repos+=("$(dirname "$d")")
    done
    IFS=$'\n' repos=($(sort <<< "${repos[*]}")); unset IFS

    repo_count=${#repos[@]}
    ri=0
    for repo in "${repos[@]}"; do
      ((ri++))
      if (( ri == repo_count )); then
        echo "└── ${repo}/"
        render_worktrees "$repo" "    "
      else
        echo "├── ${repo}/"
        render_worktrees "$repo" "│   "
      fi
    done
  else
    echo ".  (no repos — run \`git clone\` then \`git worktree add default\`)"
  fi

# Show worktrees in dependency order — merge leaves first, roots last
[group("human")]
worktree-deps:
  #!/usr/bin/env bash
  cd "${TK_PROJECT_DIR:-{{ justfile_directory() }}}"
  JUSTFILE="{{ justfile() }}"
  WORKING_DIR="${TK_PROJECT_DIR:-{{ justfile_directory() }}}"

  # 1. Discover repos and worktrees (same pattern as worktree-list)
  if [[ -d "default" ]]; then
    repos=(".")
  elif compgen -G "*/default" > /dev/null 2>&1; then
    repos=()
    for d in */default; do repos+=("$(dirname "$d")"); done
  else
    echo "(no repos)"
    exit 0
  fi

  single_repo=false
  [[ ${#repos[@]} -eq 1 && "${repos[0]}" == "." ]] && single_repo=true

  declare -A all_wts  # "repo/wt_name" → 1
  for repo in "${repos[@]}"; do
    if wt_output=$(git -C "$repo/default" worktree list --porcelain 2>/dev/null); then
      while IFS= read -r line; do
        [[ "$line" == worktree\ * ]] || continue
        name=$(basename "${line#worktree }")
        [[ "$name" == "default" ]] && continue
        all_wts["$repo/$name"]=1
      done <<< "$wt_output"
    fi
  done

  if [[ ${#all_wts[@]} -eq 0 ]]; then
    echo "(no feature worktrees)"
    exit 0
  fi

  # 2. Map features → worktrees, extract upstream feature deps
  declare -A feat_wt feat_repo feat_exists feat_upstream feat_closed
  declare -A matched  # "repo/wt_name" → 1

  while IFS= read -r feat_json; do
    [[ -z "$feat_json" ]] && continue
    feat_id=$(echo "$feat_json" | jq -r '.id')
    feat_status=$(echo "$feat_json" | jq -r '.status // "open"')
    [[ "$feat_status" == "closed" ]] && feat_closed["$feat_id"]=1
    repo_tag=$(echo "$feat_json" | jq -r '(.tags // [] | map(select(startswith("repo:"))) | first // ".") | ltrimstr("repo:")')

    wt_name=$(just --justfile "$JUSTFILE" --working-directory "$WORKING_DIR" worktree-name "$feat_id" 2>/dev/null)
    [[ -z "$wt_name" ]] && continue

    feat_wt["$feat_id"]="$wt_name"

    # Match worktree: try repo tag first, then search all repos as fallback
    key="$repo_tag/$wt_name"
    if [[ -v "all_wts[$key]" ]]; then
      feat_exists["$feat_id"]=1
      feat_repo["$feat_id"]="$repo_tag"
      matched["$key"]=1
    else
      # Fallback: search all repos for this worktree name (handles missing repo: tags)
      found=false
      for candidate in "${!all_wts[@]}"; do
        if [[ "$candidate" == *"/$wt_name" ]]; then
          feat_exists["$feat_id"]=1
          feat_repo["$feat_id"]="${candidate%/$wt_name}"
          matched["$candidate"]=1
          found=true
          break
        fi
      done
      if [[ "$found" != "true" ]]; then
        feat_exists["$feat_id"]=0
        feat_repo["$feat_id"]="$repo_tag"
      fi
    fi

    # Find upstream feature dep (first feature-type dep)
    while IFS= read -r dep_id; do
      [[ -z "$dep_id" ]] && continue
      dep_type=$({{ tk }} query "select(.id == \"$dep_id\")" 2>/dev/null | jq -r '.type // empty')
      if [[ "$dep_type" == "feature" ]]; then
        feat_upstream["$feat_id"]="$dep_id"
        break
      fi
    done < <(echo "$feat_json" | jq -r '.deps[]?' 2>/dev/null)
  done < <({{ tk }} query 'select(.type == "feature")' 2>/dev/null)

  # 2.5. Prune resolved upstream deps (upstream merged and downstream already has those changes)
  for fid in "${!feat_upstream[@]}"; do
    up="${feat_upstream[$fid]}"
    # Only prune when upstream is closed (merged), has no worktree, and downstream has a worktree
    if [[ "${feat_closed[$up]:-0}" == "1" && "${feat_exists[$up]:-0}" == "0" && "${feat_exists[$fid]:-0}" == "1" ]]; then
      repo="${feat_repo[$fid]}"
      wt="${feat_wt[$fid]}"
      if [[ -d "$repo/$wt" ]]; then
        # If origin/HEAD is an ancestor of the downstream branch, the merged upstream
        # changes are already included — no need to show the dep as a ghost
        if git -C "$repo/$wt" merge-base --is-ancestor origin/HEAD HEAD 2>/dev/null; then
          unset "feat_upstream[$fid]"
        fi
      fi
    fi
  done

  # 3. Determine visible set + ghost detection
  declare -A visible ghost

  # Features with existing worktrees are always visible
  for fid in "${!feat_exists[@]}"; do
    [[ "${feat_exists[$fid]}" == "1" ]] && visible["$fid"]=1
  done

  # Walk upstream from each visible feature — missing worktrees become ghosts
  # Inherit repo from the descendant that triggered the ghost
  for fid in "${!visible[@]}"; do
    current="${feat_upstream[$fid]:-}"
    child="$fid"
    while [[ -n "$current" && -v "feat_wt[$current]" ]]; do
      if [[ "${feat_exists[$current]:-0}" == "0" && ! -v "visible[$current]" ]]; then
        visible["$current"]=1
        ghost["$current"]=1
        feat_repo["$current"]="${feat_repo[$child]:-${feat_repo[$current]:-}}"
      fi
      child="$current"
      current="${feat_upstream[$current]:-}"
    done
  done

  # 4. Build children map + find roots
  declare -A children  # feat_id → space-separated child feat_ids
  roots=()

  for fid in "${!visible[@]}"; do
    up="${feat_upstream[$fid]:-}"
    if [[ -n "$up" && -v "visible[$up]" ]]; then
      children["$up"]="${children[$up]:-} $fid"
    else
      roots+=("$fid")
    fi
  done

  # Sort roots by worktree name
  if [[ ${#roots[@]} -gt 0 ]]; then
    IFS=$'\n' roots=($(for r in "${roots[@]}"; do echo "${feat_wt[$r]} $r"; done | sort | awk '{print $2}')); unset IFS
  fi

  # 5. Render tree
  render_node() {
    local fid="$1" prefix="$2" connector="$3"
    local wt="${feat_wt[$fid]}"
    local label="$wt/  ($fid)"

    if [[ "$single_repo" != "true" ]]; then
      label="${feat_repo[$fid]}/$label"
    fi

    if [[ -v "ghost[$fid]" ]]; then
      label="$label  (merged — rebase children with just rebase-feature)"
    fi

    echo "${prefix}${connector}${label}"

    local child_prefix="$prefix"
    if [[ "$connector" == "├── " ]]; then
      child_prefix="${prefix}│   "
    elif [[ "$connector" == "└── " ]]; then
      child_prefix="${prefix}    "
    fi

    local kids=(${children[$fid]:-})
    if [[ ${#kids[@]} -gt 0 ]]; then
      IFS=$'\n' kids=($(for k in "${kids[@]}"; do echo "${feat_wt[$k]} $k"; done | sort | awk '{print $2}')); unset IFS
      local count=${#kids[@]}
      local i=0
      for kid in "${kids[@]}"; do
        ((i++))
        if (( i == count )); then
          render_node "$kid" "$child_prefix" "└── "
        else
          render_node "$kid" "$child_prefix" "├── "
        fi
      done
    fi
  }

  for root in "${roots[@]}"; do
    render_node "$root" "" ""
  done

  # 6. Unmatched worktrees (no feature ticket)
  unmatched=()
  for key in "${!all_wts[@]}"; do
    if [[ ! -v "matched[$key]" ]]; then
      if [[ "$single_repo" == "true" ]]; then
        unmatched+=("${key#./}/")
      else
        unmatched+=("$key/")
      fi
    fi
  done

  if [[ ${#unmatched[@]} -gt 0 ]]; then
    IFS=$'\n' unmatched=($(sort <<< "${unmatched[*]}")); unset IFS
    echo ""
    echo "(unmatched — no feature ticket)"
    for u in "${unmatched[@]}"; do
      echo "  $u"
    done
  fi

# Derive worktree/branch name from a ticket (resolves tasks to parent feature).
# Uses external-ref field on the feature if present (preserving original case),
# otherwise falls back to the tk feature ID.
[group('orchestrator')]
worktree-name ticket-id:
  #!/usr/bin/env bash
  ticket_json=$({{ tk }} query 'select(.id | contains("{{ ticket-id }}"))')
  ticket_type=$(echo "$ticket_json" | jq -r '.type')
  ticket_id=$(echo "$ticket_json" | jq -r '.id')

  # Resolve to feature: if this is a task, use its parent
  if [[ "$ticket_type" == "task" ]]; then
    parent=$(echo "$ticket_json" | jq -r '.parent // empty')
    if [[ -n "$parent" ]]; then
      ticket_json=$({{ tk }} query "select(.id == \"$parent\")")
      ticket_id=$(echo "$ticket_json" | jq -r '.id')
    fi
  fi

  # Check for external-ref field — use as name prefix instead of tk ID
  prefix=$(echo "$ticket_json" | jq -r '.["external-ref"] // empty')

  title=$({{ tk }} show "$ticket_id" | grep '^# ' | head -1 | sed 's/^# //')
  slug=$(echo "$title" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]/-/g; s/--*/-/g; s/-$//')

  if [[ -n "$prefix" ]]; then
    echo "$prefix-$slug"
  else
    echo "$ticket_id-$slug"
  fi

# Resolve which repo directory a feature's worktree lives in.
# Checks repo: tag first, then searches the filesystem as fallback.
[group('orchestrator')]
resolve-repo feature-id:
  #!/usr/bin/env bash
  cd "${TK_PROJECT_DIR:-{{ justfile_directory() }}}"
  feature_json=$({{ tk }} query "select(.id == \"{{ feature-id }}\")" 2>/dev/null)
  repo=$(echo "$feature_json" | jq -r '(.tags // [] | map(select(startswith("repo:"))) | first // ".") | ltrimstr("repo:")')
  wt=$(just --justfile "{{ justfile() }}" --working-directory "${TK_PROJECT_DIR:-.}" worktree-name "{{ feature-id }}")

  # Direct match
  if [[ -d "$repo/$wt" ]]; then
    echo "$repo"
    exit 0
  fi

  # Fallback: search all repo directories for this worktree
  if [[ -d "default" ]]; then
    candidates=(".")
  elif compgen -G "*/default" > /dev/null 2>&1; then
    candidates=()
    for d in */default; do candidates+=("$(dirname "$d")"); done
  fi

  for candidate in "${candidates[@]:-}"; do
    if [[ -d "$candidate/$wt" ]]; then
      echo "$candidate"
      exit 0
    fi
  done

  # Nothing found — return the tag value (caller will get the error on dir check)
  echo "$repo"

# Resolve the base branch for a feature — checks deps for upstream features (stacked branches)
[group('orchestrator')]
resolve-base-branch feature-id:
  #!/usr/bin/env bash
  cd "${TK_PROJECT_DIR:-{{ justfile_directory() }}}"
  feature_json=$({{ tk }} query "select(.id == \"{{ feature-id }}\")")

  # Find repo for this feature (needed to check branch existence)
  repo=$(echo "$feature_json" | jq -r '(.tags // [] | map(select(startswith("repo:"))) | first // ".") | ltrimstr("repo:")')

  while IFS= read -r dep_id; do
    [[ -z "$dep_id" ]] && continue
    dep_json=$({{ tk }} query "select(.id == \"$dep_id\")" 2>/dev/null)
    [[ -z "$dep_json" ]] && continue
    dep_type=$(echo "$dep_json" | jq -r '.type')
    if [[ "$dep_type" == "feature" ]]; then
      upstream_wt=$(just --justfile "{{ justfile() }}" \
        --working-directory "${TK_PROJECT_DIR:-.}" worktree-name "$dep_id")
      dep_status=$(echo "$dep_json" | jq -r '.status')
      if [[ "$dep_status" == "closed" ]]; then
        # Upstream closed — use its branch if it still exists (not yet merged/deleted),
        # otherwise fall back to origin/HEAD
        if [[ -n "$upstream_wt" ]] && git -C "$repo/default" rev-parse --verify "$upstream_wt" &>/dev/null; then
          echo "$upstream_wt"
        else
          echo "${TK_BASE_BRANCH:-origin/HEAD}"
        fi
        exit 0
      fi
      if [[ -n "$upstream_wt" ]]; then
        echo "$upstream_wt"
        exit 0
      fi
    fi
  done < <(echo "$feature_json" | jq -r '.deps[]?' 2>/dev/null)
  echo "${TK_BASE_BRANCH:-origin/HEAD}"

[group('orchestrator')]
create-worktree name repo="." base="${TK_BASE_BRANCH:-origin/HEAD}":
  #!/usr/bin/env bash
  set -euo pipefail
  PROJECT_DIR="{{ justfile_directory() }}"
  WORKTREE_DIR="{{ repo }}/{{ name }}"
  REPO="{{ repo }}"

  # Fetch latest and create worktree from the specified base
  git -C "{{ repo }}/default" fetch origin 2>/dev/null || true
  git -C "{{ repo }}/default" worktree add --no-track -b "{{ name }}" "../{{ name }}" "{{ base }}" 2>/dev/null || true

  if [[ -d ".claude" && -d "$WORKTREE_DIR" ]]; then
    # Merge tk agents (creates actual files from base + extensions)
    BASE_DIR="$PROJECT_DIR/.claude/agents/tk"
    DEFAULT_DIR="$PROJECT_DIR/.jr/claude/_/agents/tk"
    REPO_DIR="$PROJECT_DIR/.jr/claude/$REPO/agents/tk"
    TARGET_DIR="$WORKTREE_DIR/.claude/agents/tk"

    if [[ -d "$BASE_DIR" ]]; then
      mkdir -p "$TARGET_DIR"
      for base in "$BASE_DIR"/*.md; do
        [[ -f "$base" ]] || continue
        agent=$(basename "$base" .md)
        merged="$TARGET_DIR/$agent.md"
        cat "$base" > "$merged"
        [[ -f "$DEFAULT_DIR/$agent.md" ]] && { echo -e "\n" >> "$merged"; cat "$DEFAULT_DIR/$agent.md" >> "$merged"; }
        [[ "$REPO" != "." && -f "$REPO_DIR/$agent.md" ]] && { echo -e "\n" >> "$merged"; cat "$REPO_DIR/$agent.md" >> "$merged"; }
      done
    fi

    # Copy project-level .jr rules
    DEFAULT_RULES="$PROJECT_DIR/.jr/claude/_/rules"
    REPO_RULES="$PROJECT_DIR/.jr/claude/$REPO/rules"
    TARGET_RULES="$WORKTREE_DIR/.claude/rules"

    if [[ -d "$DEFAULT_RULES" ]] && compgen -G "$DEFAULT_RULES/*.md" >/dev/null; then
      mkdir -p "$TARGET_RULES"
      cp "$DEFAULT_RULES"/*.md "$TARGET_RULES/"
    fi
    if [[ "$REPO" != "." && -d "$REPO_RULES" ]] && compgen -G "$REPO_RULES/*.md" >/dev/null; then
      mkdir -p "$TARGET_RULES"
      cp "$REPO_RULES"/*.md "$TARGET_RULES/"
    fi

    # Then rsync the rest (--ignore-existing preserves our files)
    rsync -a --ignore-existing --exclude='settings.local.json' --exclude='prompts/' .claude/ "$WORKTREE_DIR/.claude/"
  fi

  grep -qxF '.claude/agents/tk/' "{{ repo }}/default/.git/info/exclude" 2>/dev/null \
    || printf '%s\n' '.claude/agents/tk/' '.claude/commands/tk/' '.claude/rules/tk-agents.md' \
      >> "{{ repo }}/default/.git/info/exclude"

[group('orchestrator')]
remove-worktree name repo=".":
  git -C {{ repo }}/default worktree remove ../{{ name }}
  git -C {{ repo }}/default branch -d {{ name }}

# Run the orchestration loop — discovers ready work, launches subagents, reacts to signals
[group("human")]
start-work *args:
  #!/usr/bin/env bash
  set -o pipefail

  # --- Configuration ---
  MAX_CONCURRENT="${TK_MAX_CONCURRENT:-3}"
  REVIEW_ROUNDS="${TK_REVIEW_ROUNDS:-5}"
  NO_HUMAN_REVIEW="${TK_NO_HUMAN_REVIEW:-0}"
  for arg in {{ args }}; do
    case "$arg" in
      --no-human-review) NO_HUMAN_REVIEW=1 ;;
    esac
  done
  PROJECT_DIR="${TK_PROJECT_DIR:-{{ justfile_directory() }}}"
  OUTPUT_DIR="${TK_OUTPUT_DIR:-$PROJECT_DIR/.jr/tmp}"
  LOCK_DIR="$OUTPUT_DIR/locks"
  CLAUDE="${CLAUDE_CMD:-claude}"
  JUSTFILE="{{ justfile() }}"
  AGENT_TIMEOUT="${TK_AGENT_TIMEOUT:-3600}"

  cd "$PROJECT_DIR"

  # --- State ---
  declare -A PID_TO_TICKET     # pid → ticket-id
  declare -A PID_TO_AGENT      # pid → agent name
  declare -A PID_TO_WORKTREE   # pid → worktree-name (lock name)
  declare -A PID_TO_START_TS   # pid → epoch seconds when launched
  declare -A PID_TO_TITLE      # pid → ticket title
  declare -A PID_TO_TYPE       # pid → ticket type (task or feature)
  declare -A BUSY_WORKTREES    # worktree-name → pid
  declare -A LOGGED_FEATURES   # feature-id → 1 (already logged as ready for human review)
  declare -A LAUNCHED_THIS_RUN # ticket-id → 1 (launched this orchestrator run)
  ESCALATION=""                # non-empty = stop launching, drain, exit

  # --- Functions ---

  log() { echo "[orchestrator] $*"; }

  setup() {
    mkdir -p "$OUTPUT_DIR" "$LOCK_DIR"
    : > "$OUTPUT_DIR/sessions.jsonl"
    # Clean stale lockfiles (symlinks: target is the PID)
    for lockfile in "$LOCK_DIR"/*.lock; do
      [[ -L "$lockfile" ]] || continue
      local pid
      pid=$(readlink "$lockfile" 2>/dev/null || true)
      if [[ -n "$pid" ]] && ! kill -0 "$pid" 2>/dev/null; then
        log "Cleaning stale lockfile: $lockfile (pid $pid)"
        rm -f "$lockfile"
      fi
    done
    log "Starting orchestration"
    log "Ready tickets:"
    {{ tk }} ready 2>/dev/null || true
  }

  acquire_lock() {
    local name="$1" pid="$2"
    local lockfile="$LOCK_DIR/$name.lock"
    if ln -s "$pid" "$lockfile" 2>/dev/null; then
      return 0
    fi
    local existing_pid
    existing_pid=$(readlink "$lockfile" 2>/dev/null || true)
    if [[ -n "$existing_pid" ]] && ! kill -0 "$existing_pid" 2>/dev/null; then
      rm -f "$lockfile"
      ln -s "$pid" "$lockfile" 2>/dev/null && return 0
    fi
    return 1
  }

  release_lock() {
    local name="$1"
    rm -f "$LOCK_DIR/$name.lock"
  }

  active_count() {
    echo "${#PID_TO_TICKET[@]}"
  }

  get_ready_tickets() {
    local ready_ids
    ready_ids=$({{ tk }} ready 2>/dev/null | grep -oP '^[a-z0-9]+-[a-z0-9]+' || true)
    if [[ -z "$ready_ids" ]]; then
      return
    fi
    while IFS= read -r id; do
      {{ tk }} query "select(.id == \"$id\")" | jq -c '{id: .id, type: .type, assignee: .assignee, tags: .tags, parent: .parent}'
    done <<< "$ready_ids"
  }

  worktree_name() {
    local ticket_id="$1"
    just --justfile "$JUSTFILE" --working-directory "$PROJECT_DIR" worktree-name "$ticket_id"
  }

  resolve_base_branch() {
    local feature_id="$1"
    just --justfile "$JUSTFILE" --working-directory "$PROJECT_DIR" resolve-base-branch "$feature_id"
  }

  merge_tk_agents() {
    local worktree_dir="$1" repo="$2"
    local base_dir="$PROJECT_DIR/.claude/agents/tk"
    local default_dir="$PROJECT_DIR/.jr/claude/_/agents/tk"
    local repo_dir="$PROJECT_DIR/.jr/claude/$repo/agents/tk"
    local target_dir="$worktree_dir/.claude/agents/tk"

    # Skip if no base agents directory
    [[ -d "$base_dir" ]] || return 0

    mkdir -p "$target_dir"

    # Dynamic discovery: glob all .md files in base agents/tk/
    for base in "$base_dir"/*.md; do
      [[ -f "$base" ]] || continue
      local agent
      agent=$(basename "$base" .md)
      local merged="$target_dir/$agent.md"

      # Start with base (cat resolves symlinks to get actual content)
      cat "$base" > "$merged"

      # Append default (_) extension if exists
      [[ -f "$default_dir/$agent.md" ]] && {
        echo -e "\n" >> "$merged"
        cat "$default_dir/$agent.md" >> "$merged"
      }

      # Append repo-specific extension if exists (skip if repo is ".")
      [[ "$repo" != "." && -f "$repo_dir/$agent.md" ]] && {
        echo -e "\n" >> "$merged"
        cat "$repo_dir/$agent.md" >> "$merged"
      }
    done
  }

  copy_tk_rules() {
    local worktree_dir="$1" repo="$2"
    local default_dir="$PROJECT_DIR/.jr/claude/_/rules"
    local repo_dir="$PROJECT_DIR/.jr/claude/$repo/rules"
    local target_dir="$worktree_dir/.claude/rules"

    # Copy default (_) rules if any exist
    if [[ -d "$default_dir" ]] && compgen -G "$default_dir/*.md" >/dev/null; then
      mkdir -p "$target_dir"
      cp "$default_dir"/*.md "$target_dir/"
    fi

    # Copy repo-specific rules (overwrites default if same name)
    if [[ "$repo" != "." && -d "$repo_dir" ]] && compgen -G "$repo_dir/*.md" >/dev/null; then
      mkdir -p "$target_dir"
      cp "$repo_dir"/*.md "$target_dir/"
    fi
  }

  create_worktree() {
    local name="$1" repo="${2:-.}" base="${3:-${TK_BASE_BRANCH:-origin/HEAD}}"
    local git_dir="$PROJECT_DIR/$repo/default/.git"
    local worktree_dir="$PROJECT_DIR/$repo/$name"
    git -C "$PROJECT_DIR/$repo/default" fetch origin >/dev/null 2>&1 || true
    if [[ -d "$worktree_dir" ]]; then
      # Worktree already exists — still sync .claude/ but return 1
      if [[ -d "$PROJECT_DIR/.claude" ]]; then
        # Merge tk agents (creates actual files, not symlinks)
        merge_tk_agents "$worktree_dir" "$repo"
        # Copy project-level .jr rules
        copy_tk_rules "$worktree_dir" "$repo"
        # Then rsync the rest (--ignore-existing preserves our files)
        rsync -a --ignore-existing --exclude='settings.local.json' --exclude='prompts/' "$PROJECT_DIR/.claude/" "$worktree_dir/.claude/"
      fi
      return 1
    fi
    git -C "$PROJECT_DIR/$repo/default" worktree add --no-track -b "$name" "../$name" "$base" >/dev/null 2>&1 || return 1
    if [[ -d "$PROJECT_DIR/.claude" && -d "$worktree_dir" ]]; then
      # Merge tk agents (creates actual files, not symlinks)
      merge_tk_agents "$worktree_dir" "$repo"
      # Copy project-level .jr rules
      copy_tk_rules "$worktree_dir" "$repo"
      # Then rsync the rest (--ignore-existing preserves our files)
      rsync -a --ignore-existing --exclude='settings.local.json' --exclude='prompts/' "$PROJECT_DIR/.claude/" "$worktree_dir/.claude/"
    fi
    # Ensure tk-specific paths are excluded from git status
    grep -qxF '.claude/agents/tk/' "$git_dir/info/exclude" 2>/dev/null \
      || printf '%s\n' '.claude/agents/tk/' '.claude/commands/tk/' '.claude/rules/tk-agents.md' \
        >> "$git_dir/info/exclude"
  }

  count_review_rounds() {
    local ticket_id="$1" prefix="$2"
    local notes
    notes=$({{ tk }} show "$ticket_id")

    # Find reset points: last APPROVED or last Run started
    local last_approved last_run last_reset=0
    last_approved=$(echo "$notes" | grep -n "\[signal:$prefix\] APPROVED\." | tail -1 | cut -d: -f1)
    last_run=$(echo "$notes" | grep -n "\[orchestrator\] Run started" | tail -1 | cut -d: -f1)

    [[ -n "$last_approved" ]] && (( last_approved > last_reset )) && last_reset=$last_approved
    [[ -n "$last_run" ]] && (( last_run > last_reset )) && last_reset=$last_run

    if (( last_reset > 0 )); then
      echo "$notes" | tail -n +"$last_reset" | grep -cF "[signal:$prefix] CHANGES REQUESTED." || true
    else
      echo "$notes" | grep -cF "[signal:$prefix] CHANGES REQUESTED." || true
    fi
  }

  make_prompt() {
    local ticket_id="$1" repo="$2"
    local template="$PROJECT_DIR/.claude/prompts/tk/subagent-task.md"
    local default_ext="$PROJECT_DIR/.jr/claude/_/prompts/tk/subagent-task.md"
    local repo_ext="$PROJECT_DIR/.jr/claude/$repo/prompts/tk/subagent-task.md"

    local prompt=""

    # Start with base template
    if [[ -f "$template" ]]; then
      prompt=$(sed "s/\\\$ARGUMENTS\\[0\\]/$ticket_id/" "$template")
    else
      prompt="Work on \`{{ tk }} show $ticket_id\`."
    fi

    # Append default (_) extension if exists
    if [[ -f "$default_ext" ]]; then
      prompt="$prompt"$'\n\n'"$(cat "$default_ext")"
    fi

    # Append repo-specific extension if exists (skip if repo is ".")
    if [[ "$repo" != "." && -f "$repo_ext" ]]; then
      prompt="$prompt"$'\n\n'"$(cat "$repo_ext")"
    fi

    echo "$prompt"
  }

  launch() {
    local ticket_id="$1" ticket_type="$2"
    local current
    current=$(active_count)
    if (( current >= MAX_CONCURRENT )); then
      return 1
    fi

    # Get ticket metadata
    local ticket_json
    ticket_json=$({{ tk }} query "select(.id == \"$ticket_id\")")
    local agent parent title
    agent=$(echo "$ticket_json" | jq -r '.assignee')

    # Feature handling: launch if architect-assigned, skip if human or unassigned
    if [[ "$ticket_type" == "feature" ]]; then
      if [[ "$agent" == "tk:architect-reviewer" ]]; then
        : # Fall through to launch architect for feature review
      elif [[ "$agent" == "human" ]]; then
        if [[ "$NO_HUMAN_REVIEW" == "1" ]]; then
          {{ tk }} close "$ticket_id"
          log "Feature $ticket_id auto-closed (no-human-review recovery)"
          return 1
        fi
        if [[ -z "${LOGGED_FEATURES[$ticket_id]:-}" ]]; then
          log "Feature $ticket_id ready for human review"
          LOGGED_FEATURES[$ticket_id]=1
        fi
        return 1
      else
        # Unassigned or unknown — skip
        return 1
      fi
    fi
    parent=$(echo "$ticket_json" | jq -r '.parent // empty')
    title=$({{ tk }} show "$ticket_id" | grep '^# ' | head -1 | sed 's/^# //')

    # Add run marker if first launch this session (resets code-reviewer counter for tasks)
    # Skip for features — architect iteration count persists across runs
    if [[ "$ticket_type" != "feature" && -z "${LAUNCHED_THIS_RUN[$ticket_id]:-}" ]]; then
      {{ tk }} add-note "$ticket_id" "[orchestrator] Run started"
      LAUNCHED_THIS_RUN[$ticket_id]=1
    fi

    # Derive worktree from parent feature (not task)
    local repo wt feature_id base_branch
    repo=$(echo "$ticket_json" | jq -r '(.tags // [] | map(select(startswith("repo:"))) | first // ".") | ltrimstr("repo:")')

    if [[ -n "$parent" ]]; then
      feature_id="$parent"
    else
      feature_id="$ticket_id"
    fi

    wt=$(worktree_name "$ticket_id")
    if [[ -z "$wt" ]]; then
      log "ERROR: Could not derive worktree name for $ticket_id"
      return 1
    fi

    # Lock name = feature worktree name (all tasks in a feature share the lock)
    local lock_name="$wt"

    # Check lock not busy
    if [[ -n "${BUSY_WORKTREES[$lock_name]:-}" ]]; then
      return 1
    fi

    # Create worktree if needed, resolving base branch for stacked features
    base_branch=$(resolve_base_branch "$feature_id")
    local wt_created=false
    if create_worktree "$wt" "$repo" "$base_branch" 2>/dev/null; then
      wt_created=true
      log "Created worktree $repo/$wt (base: $base_branch)"
    fi
    local launch_dir="$PROJECT_DIR/$repo/$wt"
    [[ -d "$launch_dir" ]] || launch_dir="$PROJECT_DIR"

    # Add assignment note before launching coder
    if [[ "$agent" == "tk:coder" ]]; then
      {{ tk }} add-note "$ticket_id" "[orchestrator] Assigned to coder."
    fi

    # Extract model from agent frontmatter
    local agent_file model
    agent_file="$PROJECT_DIR/.claude/agents/${agent/://}.md"
    model=$(sed -n '/^---$/,/^---$/{ s/^model: *//p }' "$agent_file")

    local prompt outfile session_uuid
    prompt=$(make_prompt "$ticket_id" "$repo")
    outfile="$OUTPUT_DIR/output-$ticket_id.txt"
    session_uuid=$(uuidgen)

    log "Session: $session_uuid (ticket: $ticket_id)"

    # Launch claude as background process (exec replaces subshell so PID matches)
    (
      cd "$launch_dir"
      export MOCK_RESPONSES_DIR="${MOCK_RESPONSES_DIR:-}"
      exec timeout "$AGENT_TIMEOUT" $CLAUDE --agent "$agent" ${model:+--model "$model"} --session-id "$session_uuid" --dangerously-skip-permissions \
        -p "$prompt" < /dev/null > "$outfile" 2>&1
    ) &
    local pid=$!

    if ! acquire_lock "$lock_name" "$pid"; then
      kill "$pid" 2>/dev/null || true
      return 1
    fi

    PID_TO_TICKET[$pid]="$ticket_id"
    PID_TO_AGENT[$pid]="$agent"
    PID_TO_WORKTREE[$pid]="$lock_name"
    PID_TO_START_TS[$pid]=$(date +%s)
    PID_TO_TITLE[$pid]="$title"
    PID_TO_TYPE[$pid]="$ticket_type"
    BUSY_WORKTREES[$lock_name]="$pid"

    log "Launched $agent on $ticket_id \"$title\" in $repo/$wt (pid: $pid)"
    echo "{\"ticket\":\"$ticket_id\",\"agent\":\"$agent\",\"session\":\"$session_uuid\",\"worktree\":\"$repo/$wt\",\"pid\":$pid,\"ts\":\"$(date -Iseconds)\"}" \
      >> "$OUTPUT_DIR/sessions.jsonl"
    return 0
  }

  parse_signal() {
    local outfile="$1"
    local tail
    tail=$(tail -20 "$outfile")
    SIGNAL=$(echo "$tail" | grep -oP '^signal:\s*\K\S+' || true)
    SIGNAL_TICKET=$(echo "$tail" | grep -oP '^ticket:\s*\K\S+' || true)
    SIGNAL_SUMMARY=$(echo "$tail" | grep -oP '^summary:\s*\K.*' || true)
  }

  react() {
    local finished_pid="$1"
    local ticket_id="${PID_TO_TICKET[$finished_pid]:-}"
    local finished_agent="${PID_TO_AGENT[$finished_pid]:-}"
    local wt="${PID_TO_WORKTREE[$finished_pid]:-}"
    local ticket_type="${PID_TO_TYPE[$finished_pid]:-task}"

    if [[ -z "$ticket_id" ]]; then
      log "WARNING: Unknown PID $finished_pid finished"
      return
    fi

    # Clean up tracking state (save start_ts before unset for timeout detection)
    local start_ts="${PID_TO_START_TS[$finished_pid]:-0}"
    local title="${PID_TO_TITLE[$finished_pid]:-}"
    unset PID_TO_TICKET[$finished_pid]
    unset PID_TO_AGENT[$finished_pid]
    unset PID_TO_WORKTREE[$finished_pid]
    unset PID_TO_START_TS[$finished_pid]
    unset PID_TO_TITLE[$finished_pid]
    unset PID_TO_TYPE[$finished_pid]
    unset BUSY_WORKTREES[$wt]
    release_lock "$wt"

    # Parse signal from output
    local outfile="$OUTPUT_DIR/output-$ticket_id.txt"
    parse_signal "$outfile"

    log "Finished $ticket_id \"$title\" — signal: ${SIGNAL:-NONE}"

    # Drain mode: skip dispatch if escalation already triggered
    if [[ -n "$ESCALATION" ]]; then
      log "Drain: skipping dispatch for $ticket_id (signal: ${SIGNAL:-NONE})"
      return
    fi

    # Feature-level signals (from architect reviewing a feature)
    if [[ "$ticket_type" == "feature" ]]; then
      case "${SIGNAL:-}" in
        approved)
          if [[ "$NO_HUMAN_REVIEW" == "1" ]]; then
            {{ tk }} close "$ticket_id"
            log "Feature $ticket_id approved — closed (no-human-review)"
          else
            {{ tk }} assign "$ticket_id" human
            log "Feature $ticket_id approved by architect — assigned to human for review"
          fi
          ;;
        changes-requested)
          # Architect reopened tasks — check iteration cap then let discover() find them
          local arch_count
          arch_count=$(count_review_rounds "$ticket_id" "architect")
          if (( arch_count >= REVIEW_ROUNDS )); then
            log "ESCALATE: Feature $ticket_id has $arch_count architect review rounds — max exceeded"
            ESCALATION="Max architect review iterations exceeded for feature $ticket_id"
            return
          fi
          log "Feature $ticket_id: architect requested changes — reopened tasks will appear in ready"
          ;;
        escalate)
          log "ESCALATE: $ticket_id — ${SIGNAL_SUMMARY:-no summary}"
          ESCALATION="Escalation from $ticket_id: ${SIGNAL_SUMMARY:-no details}"
          ;;
        *)
          local now duration
          now=$(date +%s)
          duration=$((now - start_ts))
          if [[ $duration -ge $((AGENT_TIMEOUT - 10)) ]]; then
            log "TIMEOUT: $ticket_id timed out after ${duration}s"
            local session_uuid
            session_uuid=$(grep "\"ticket\":\"$ticket_id\"" "$OUTPUT_DIR/sessions.jsonl" | tail -1 | jq -r '.session // empty')
            {{ tk }} add-note "$ticket_id" "[orchestrator] Agent timed out after ${duration}s. Session: ${session_uuid:-unknown}"
            ESCALATION="Timeout on $ticket_id after ${duration}s"
          else
            log "ESCALATE: $ticket_id returned no valid signal"
            if [[ -f "$outfile" ]]; then
              log "Last 5 lines of output:"
              tail -5 "$outfile" | while IFS= read -r line; do log "  $line"; done
            fi
            ESCALATION="No valid signal from $ticket_id"
          fi
          ;;
      esac
      return
    fi

    # Task-level signals
    case "${SIGNAL:-}" in
      requesting-review)
        log "Assigning $ticket_id to tk:code-reviewer"
        {{ tk }} assign "$ticket_id" "tk:code-reviewer"
        launch "$ticket_id" "task" || log "Could not immediately launch reviewer for $ticket_id"
        ;;
      approved)
        log "Closing $ticket_id (approved)"
        {{ tk }} close "$ticket_id"
        ;;
      changes-requested)
        # Check iteration cap for code-reviewer
        local cr_count
        cr_count=$(count_review_rounds "$ticket_id" "code-reviewer")
        if (( cr_count >= REVIEW_ROUNDS )); then
          log "ESCALATE: $ticket_id has $cr_count code-review rounds — max exceeded"
          ESCALATION="Max review iterations exceeded for $ticket_id"
          return
        fi
        log "Assigning $ticket_id back to tk:coder"
        {{ tk }} assign "$ticket_id" "tk:coder"
        {{ tk }} add-note "$ticket_id" "[orchestrator] Assigned to coder."
        launch "$ticket_id" "task" || log "Could not immediately relaunch coder for $ticket_id"
        ;;
      escalate)
        log "ESCALATE: $ticket_id — ${SIGNAL_SUMMARY:-no summary}"
        ESCALATION="Escalation from $ticket_id: ${SIGNAL_SUMMARY:-no details}"
        ;;
      *)
        local now duration
        now=$(date +%s)
        duration=$((now - start_ts))

        if [[ $duration -ge $((AGENT_TIMEOUT - 10)) ]]; then
          # Timeout detected
          log "TIMEOUT: $ticket_id timed out after ${duration}s"
          local session_uuid
          session_uuid=$(grep "\"ticket\":\"$ticket_id\"" "$OUTPUT_DIR/sessions.jsonl" | tail -1 | jq -r '.session // empty')
          {{ tk }} add-note "$ticket_id" "[orchestrator] Agent timed out after ${duration}s. Session: ${session_uuid:-unknown}"
          ESCALATION="Timeout on $ticket_id after ${duration}s"
        else
          # Unknown failure
          log "ESCALATE: $ticket_id returned no valid signal"
          if [[ -f "$outfile" ]]; then
            log "Last 5 lines of output:"
            tail -5 "$outfile" | while IFS= read -r line; do log "  $line"; done
          fi
          ESCALATION="No valid signal from $ticket_id"
        fi
        ;;
    esac
  }

  discover() {
    [[ -n "$ESCALATION" ]] && return
    local tickets
    tickets=$(get_ready_tickets)
    [[ -z "$tickets" ]] && return
    while IFS= read -r ticket_json; do
      [[ -z "$ticket_json" ]] && continue
      local id type
      id=$(echo "$ticket_json" | jq -r '.id')
      type=$(echo "$ticket_json" | jq -r '.type')

      # Skip tickets already being worked on
      local already_running=false
      for pid in "${!PID_TO_TICKET[@]}"; do
        if [[ "${PID_TO_TICKET[$pid]}" == "$id" ]]; then
          already_running=true
          break
        fi
      done
      [[ "$already_running" == "true" ]] && continue

      launch "$id" "$type" || true
    done <<< "$tickets"
  }

  drain() {
    log "Draining — waiting for ${#PID_TO_TICKET[@]} active subagent(s)..."
    while (( ${#PID_TO_TICKET[@]} > 0 )); do
      local FINISHED_PID
      wait -n -p FINISHED_PID "${!PID_TO_TICKET[@]}" 2>/dev/null || true
      if [[ -n "${FINISHED_PID:-}" ]]; then
        react "$FINISHED_PID"
      else
        break
      fi
    done
  }

  # Walk process tree from given PIDs, collect all unique PGIDs (breadth-first).
  # Must run BEFORE killing anything — once parents die, children reparent to PID 1.
  collect_pgids() {
    local queue=("$@") seen=()
    while [[ ${#queue[@]} -gt 0 ]]; do
      local cur="${queue[0]}"; queue=("${queue[@]:1}")
      local pgid; pgid=$(ps -o pgid= -p "$cur" 2>/dev/null | tr -d ' ') || continue
      [[ -n "$pgid" ]] && seen+=("$pgid")
      while IFS= read -r child; do
        child="${child// /}"; [[ -n "$child" ]] && queue+=("$child")
      done < <(ps -o pid= --ppid "$cur" 2>/dev/null)
    done
    printf '%s\n' "${seen[@]}" | sort -un
  }

  cleanup() {
    log "Interrupted — cleaning up"
    # Snapshot all descendant PGIDs before sending any signals
    local pgids
    pgids=$(collect_pgids "${!PID_TO_TICKET[@]}")
    # Release worktree locks
    for pid in "${!PID_TO_TICKET[@]}"; do
      local wt="${PID_TO_WORKTREE[$pid]:-}"
      [[ -n "$wt" ]] && release_lock "$wt"
    done
    # SIGTERM each process group
    local my_pgid; my_pgid=$(ps -o pgid= -p $$ 2>/dev/null | tr -d ' ')
    while IFS= read -r pgid; do
      [[ -n "$pgid" && "$pgid" != "$my_pgid" ]] && kill -TERM -- -"$pgid" 2>/dev/null || true
    done <<< "$pgids"
    sleep 0.5
    # SIGKILL stragglers
    while IFS= read -r pgid; do
      [[ -n "$pgid" && "$pgid" != "$my_pgid" ]] && kill -KILL -- -"$pgid" 2>/dev/null || true
    done <<< "$pgids"
    exit 130
  }

  # --- Main ---

  trap cleanup SIGINT SIGTERM

  setup

  while true; do
    discover

    if (( ${#PID_TO_TICKET[@]} == 0 )); then
      # Check ready tickets for human review gate or launchable work
      ready_count=0; human_features=0; launchable=0
      human_feature_names=()
      ready_count=$({{ tk }} ready 2>/dev/null | grep -c '^[a-z]') || true

      if (( ready_count > 0 )); then
        while IFS= read -r line; do
          [[ -z "$line" ]] && continue
          rid="" rtype="" rassignee=""
          rid=$(echo "$line" | grep -oP '^[a-z0-9]+-[a-z0-9]+' || true)
          [[ -z "$rid" ]] && continue
          rjson=""
          rjson=$({{ tk }} query "select(.id == \"$rid\")" 2>/dev/null || true)
          rtype=$(echo "$rjson" | jq -r '.type' 2>/dev/null || true)
          rassignee=$(echo "$rjson" | jq -r '.assignee // empty' 2>/dev/null || true)

          if [[ "$rtype" == "feature" && "$rassignee" == "human" ]]; then
            human_features=$((human_features + 1))
            rtitle=""
            rtitle=$(echo "$rjson" | jq -r '.title // .id' 2>/dev/null || echo "$rid")
            human_feature_names+=("$rid: $rtitle")
          elif [[ "$rtype" == "task" || "$rassignee" == "tk:architect-reviewer" ]]; then
            launchable=$((launchable + 1))
          fi
        done < <({{ tk }} ready 2>/dev/null || true)

        if (( human_features > 0 && launchable == 0 )); then
          # Only human-assigned features remain — human review gate
          log "All automated work complete — features awaiting human review"
          commit_body=""
          for fname in "${human_feature_names[@]}"; do
            commit_body+=$'\n'"- $fname"
          done
          just --justfile "$JUSTFILE" --working-directory "$PROJECT_DIR" commit-tickets "chore: ticket checkpoint — features awaiting review${commit_body}" || log "Warning: ticket commit failed (non-fatal)"
          printf '\a'
          exit 3
        elif (( launchable > 0 )); then
          sleep 1
          continue
        fi
      fi

      open_count=0
      open_count=$({{ tk }} query 'select(.status == "open" or .status == "in_progress")' 2>/dev/null | wc -l) || true
      if (( open_count == 0 )); then
        log "All work complete"
        printf '\a'
        exit 0
      else
        log "DEADLOCK: $open_count open ticket(s) but none are ready"
        printf '\a'
        exit 2
      fi
    fi

    # Wait for any child to finish
    FINISHED_PID=""
    wait -n -p FINISHED_PID "${!PID_TO_TICKET[@]}" 2>/dev/null || true

    if [[ -n "${FINISHED_PID:-}" ]]; then
      react "$FINISHED_PID"
    fi

    # If escalation triggered, drain remaining and exit
    if [[ -n "$ESCALATION" ]]; then
      if (( ${#PID_TO_TICKET[@]} > 0 )); then
        drain
      fi
      log "Exiting due to escalation: $ESCALATION"
      printf '\a'
      exit 2
    fi
  done

# Commit and optionally push .jr/.tickets/ changes
[group('orchestrator')]
commit-tickets subject:
  #!/usr/bin/env bash
  set -euo pipefail
  project_dir="${TK_PROJECT_DIR:-{{ justfile_directory() }}}"
  git -C "$project_dir/.jr" add .tickets/
  if git -C "$project_dir/.jr" diff --cached --quiet; then
    echo "No ticket changes to commit"
    exit 0
  fi
  git -C "$project_dir/.jr" commit -m "{{ subject }}"
  if git -C "$project_dir/.jr" remote get-url origin &>/dev/null; then
    git -C "$project_dir/.jr" push
  fi

# Print tab-delimited session entries to stdout (used by watch + fzf reload)
[group('watch')]
_watch-list:
  #!/usr/bin/env bash
  set -euo pipefail

  output_dir="${TK_OUTPUT_DIR:-{{ justfile_directory() }}/.jr/tmp}"
  sessions_file="$output_dir/sessions.jsonl"

  if [[ ! -f "$sessions_file" ]] || [[ ! -s "$sessions_file" ]]; then
    exit 0
  fi

  seq=0
  while IFS= read -r line; do
    s_ticket=$(echo "$line" | jq -r .ticket)
    s_agent=$(echo "$line" | jq -r '.agent | ltrimstr("tk:")')
    s_pid=$(echo "$line" | jq -r .pid)
    s_session=$(echo "$line" | jq -r .session)
    s_worktree=$(echo "$line" | jq -r .worktree)
    s_title=$({{ tk }} show "$s_ticket" 2>/dev/null | grep '^# ' | head -1 | sed 's/^# //' || true)

    if kill -0 "$s_pid" 2>/dev/null; then
      status="running"
    else
      status="done"
    fi

    seq=$((seq + 1))
    printf '%d\t%06d\t%-9s %-12s %-18s %-30s %s\t%s\t%s\n' "$( [[ "$status" == "running" ]] && echo 0 || echo 1 )" "$seq" "[$status]" "$s_ticket" "$s_agent" "$s_title" "$s_worktree" "$s_session" "$s_worktree"
  done < "$sessions_file" | sort -t$'\t' -k1,1n -k2,2rn | cut -f3-

# Watch a running or completed subagent session (auto-refreshing)
[group("human")]
watch:
  #!/usr/bin/env bash
  set -euo pipefail

  project_dir="{{ justfile_directory() }}"
  export TK_OUTPUT_DIR="${TK_OUTPUT_DIR:-{{ justfile_directory() }}/.jr/tmp}"

  reload_cmd="just --justfile {{ justfile() }} --working-directory $project_dir _watch-list"

  initial=$($reload_cmd)
  if [[ -z "$initial" ]]; then
    echo "No sessions found. Is the orchestrator running?" >&2
    exit 1
  fi

  export WATCH_PROJECT_DIR="$project_dir"
  export WATCH_JQ_FILTER='
    select(.type == "assistant" and .message.content) |
    .message.content[] |
    if .type == "text" then .text
    elif .type == "thinking" then "[thinking] " + .thinking
    elif .type == "tool_use" then
      if .name == "Write" or .name == "Edit" then "[" + .name + "] " + .input.file_path
      elif .name == "Read" then "[Read] " + .input.file_path
      elif .name == "Bash" then "[Bash] " + (.input.command | .[0:100])
      else "[" + .name + "] " + (.input | tostring | .[0:150])
      end
    else empty end
  '

  # Auto-refresh: background poller watches sessions.jsonl, sends reload to fzf via HTTP
  port=$((RANDOM % 10000 + 20000))
  sessions_file="$TK_OUTPUT_DIR/sessions.jsonl"
  follow_file=$(mktemp)
  echo "on" > "$follow_file"

  (
    prev_mtime=""; prev_lines=0
    while true; do
      sleep 3
      [[ -f "$sessions_file" ]] || continue
      curr_mtime=$(stat -c %Y "$sessions_file" 2>/dev/null)
      [[ "$curr_mtime" == "$prev_mtime" ]] && continue
      curr_lines=$(wc -l < "$sessions_file")
      if (( curr_lines > prev_lines )) && grep -q on "$follow_file" 2>/dev/null; then
        curl -s -XPOST "localhost:$port" -d "reload($reload_cmd)+first" 2>/dev/null
      else
        curl -s -XPOST "localhost:$port" -d "reload($reload_cmd)" 2>/dev/null
      fi
      prev_mtime="$curr_mtime"; prev_lines="$curr_lines"
    done
  ) &
  watcher_pid=$!
  trap "kill $watcher_pid 2>/dev/null; rm -f $follow_file" EXIT

  header_base="STATUS    TICKET       AGENT              TASK                           WORKTREE"

  selected=$(echo "$initial" | fzf --no-sort --track \
    --listen-unsafe "$port" \
    --delimiter=$'\t' --with-nth=1 \
    --prompt="Select session: " \
    --header="$header_base  (auto-follow ON | ctrl-f: toggle)" \
    --bind "ctrl-f:execute-silent(if grep -q on $follow_file; then echo off > $follow_file; else echo on > $follow_file; fi)+transform-header(if grep -q on $follow_file; then echo '$header_base  (auto-follow ON | ctrl-f: toggle)'; else echo '$header_base  (auto-follow OFF | ctrl-f: toggle)'; fi)" \
    --preview='
      printf "\033[2J"
      session={2}; wt={3}
      worktree_path=$(echo "$WATCH_PROJECT_DIR/$wt" | sed "s|/\./|/|g")
      escaped_path=$(echo "$worktree_path" | sed "s|[/.]|-|g")
      session_file="$HOME/.claude/projects/$escaped_path/$session.jsonl"
      [[ -f "$session_file" ]] || { echo "Session file not found"; exit 0; }
      jq -r "$WATCH_JQ_FILTER" "$session_file" 2>/dev/null
      tail -n 0 -f "$session_file" | stdbuf -oL jq -r --unbuffered "$WATCH_JQ_FILTER" 2>/dev/null
    ' \
    --preview-window='down:80%:follow:wrap') || exit 0

  # Enter pressed — fullscreen tail of selected session
  session=$(echo "$selected" | cut -d$'\t' -f2)
  wt=$(echo "$selected" | cut -d$'\t' -f3)
  worktree_path=$(echo "$WATCH_PROJECT_DIR/$wt" | sed 's|/\./|/|g')
  escaped_path=$(echo "$worktree_path" | sed 's|[/.]|-|g')
  session_file="$HOME/.claude/projects/$escaped_path/$session.jsonl"

  if [[ ! -f "$session_file" ]]; then
    echo "Session file not found: $session_file" >&2
    exit 1
  fi

  display=$(echo "$selected" | cut -d$'\t' -f1)
  echo "Watching: $display"
  echo "File: $session_file"
  echo "---"
  tail -n +1 -f "$session_file" | stdbuf -oL jq -r --unbuffered "$WATCH_JQ_FILTER" 2>/dev/null

# List commit SHAs for a task (found by Tk-Task trailer)
[group('subagent-code-reviewer')]
task-commits ticket-id repo='.':
  #!/usr/bin/env bash
  set -euo pipefail
  JUSTFILE="{{ justfile() }}"
  WORKING_DIR="${TK_PROJECT_DIR:-{{ justfile_directory() }}}"
  wt=$(just --justfile "$JUSTFILE" --working-directory "$WORKING_DIR" worktree-name "{{ ticket-id }}")
  git -C "$WORKING_DIR/{{ repo }}/$wt" log --reverse --format='%H' --grep="Tk-Task: {{ ticket-id }}" HEAD

# Show per-commit diffs for a task in chronological order
[group('subagent-code-reviewer')]
task-diff ticket-id repo='.':
  #!/usr/bin/env bash
  set -euo pipefail
  JUSTFILE="{{ justfile() }}"
  WORKING_DIR="${TK_PROJECT_DIR:-{{ justfile_directory() }}}"
  wt=$(just --justfile "$JUSTFILE" --working-directory "$WORKING_DIR" worktree-name "{{ ticket-id }}")
  commits=$(just --justfile "$JUSTFILE" --working-directory "$WORKING_DIR" task-commits "{{ ticket-id }}" "{{ repo }}")
  echo "$commits" | while read -r sha; do
    [[ -z "$sha" ]] && continue
    git -C "$WORKING_DIR/{{ repo }}/$wt" show --stat -p "$sha"
  done

# Output signal block and add completion note — use this instead of manual signal output
[group('subagent-coder'), group('subagent-code-reviewer'), group('subagent-architect-reviewer')]
signal type ticket-id summary role="":
  #!/usr/bin/env bash
  set -e
  type="{{ type }}"
  ticket="{{ ticket-id }}"
  summary="{{ summary }}"
  role="{{ role }}"

  case "$type" in
    requesting-review) agent="${role:-coder}"; prefix="Requesting review" ;;
    approved) agent="${role:-code-reviewer}"; prefix="APPROVED" ;;
    changes-requested) agent="${role:-code-reviewer}"; prefix="CHANGES REQUESTED" ;;
    rebase-complete) agent="${role:-rebaser}"; prefix="Rebase complete" ;;
    escalate)
      if [[ -n "$role" ]]; then
        agent="$role"
      else
        assignee=$({{ tk }} query "select(.id == \"$ticket\")" | jq -r '.assignee // "tk:coder"')
        agent="${assignee#tk:}"
      fi
      prefix="Escalating"
      ;;
    *) echo "Unknown signal type: $type" >&2; exit 1 ;;
  esac

  {{ tk }} add-note "$ticket" "[signal:$agent] $prefix. $summary"
  echo "---"
  echo "signal: $type"
  echo "ticket: $ticket"
  echo "summary: $summary"
  exit 0

# Acquire exclusive lock on a named resource, then run command.
# Usage: just with-lock <resource> <command> [args...]
[no-cd]
[group('subagent-coder'), group('subagent-code-reviewer'), group('subagent-architect-reviewer')]
with-lock resource *command:
  #!/usr/bin/env bash
  set -euo pipefail

  LOCK_DIR="${TK_PROJECT_DIR:-{{ justfile_directory() }}}/.jr/tmp/locks"
  LOCK_FILE="$LOCK_DIR/{{ resource }}.lock"
  LOCK_INFO="$LOCK_FILE.info"
  mkdir -p "$LOCK_DIR"

  exec 200>"$LOCK_FILE"

  if ! flock --nonblock 200 2>/dev/null; then
    HOLDER=""
    [[ -f "$LOCK_INFO" ]] && HOLDER=" ($(cat "$LOCK_INFO"))"
    echo "[with-lock:{{ resource }}] Waiting...${HOLDER}"
  fi

  flock 200

  echo "worktree=$(basename "$PWD") pid=$$ time=$(date -Iseconds)" > "$LOCK_INFO"
  echo "[with-lock:{{ resource }}] Acquired"

  set +e
  {{ command }}
  EXIT_CODE=$?
  set -e

  echo "[with-lock:{{ resource }}] Released"
  exit $EXIT_CODE

# Show status of all resource locks
[group("human")]
locks:
  #!/usr/bin/env bash
  LOCK_DIR="${TK_PROJECT_DIR:-{{ justfile_directory() }}}/.jr/tmp/locks"

  if [[ ! -d "$LOCK_DIR" ]] || ! compgen -G "$LOCK_DIR/*.lock" >/dev/null; then
    echo "No locks found"
    exit 0
  fi

  for lockfile in "$LOCK_DIR"/*.lock; do
    resource=$(basename "$lockfile" .lock)
    info_file="$lockfile.info"

    if flock --nonblock "$lockfile" -c true 2>/dev/null; then
      echo "$resource: free"
    else
      if [[ -f "$info_file" ]]; then
        echo "$resource: held ($(cat "$info_file"))"
      else
        echo "$resource: held (unknown)"
      fi
    fi
  done

# Verify ticket structure — checks for linear chains and cross-feature deps
[group('plan-features')]
verify-tickets:
  #!/usr/bin/env bash
  set -e

  cd "${TK_PROJECT_DIR:-{{ justfile_directory() }}}"

  errors=0

  # Collect all features with their children
  declare -A FEATURE_CHILDREN  # feature-id → space-separated list of child task IDs

  while IFS= read -r task_json; do
    [[ -z "$task_json" ]] && continue
    task_id=$(echo "$task_json" | jq -r '.id')
    task_parent=$(echo "$task_json" | jq -r '.parent // empty')
    [[ -z "$task_parent" ]] && continue
    FEATURE_CHILDREN[$task_parent]="${FEATURE_CHILDREN[$task_parent]:-} $task_id"
  done < <({{ tk }} query 'select(.type == "task")' 2>/dev/null)

  # Check 1: No cross-feature task dependencies
  while IFS= read -r task_json; do
    [[ -z "$task_json" ]] && continue

    task_id=$(echo "$task_json" | jq -r '.id')
    task_parent=$(echo "$task_json" | jq -r '.parent // empty')

    # Skip tasks without a parent (orphan tasks are allowed but unusual)
    [[ -z "$task_parent" ]] && continue

    # Get dependencies directly from the ticket's deps array
    while IFS= read -r dep_id; do
      [[ -z "$dep_id" ]] && continue

      # Get dependency ticket info
      dep_json=$({{ tk }} query "select(.id == \"$dep_id\")" 2>/dev/null)
      [[ -z "$dep_json" ]] && continue

      dep_type=$(echo "$dep_json" | jq -r '.type')

      # Only check task dependencies (features are allowed cross-feature)
      if [[ "$dep_type" == "task" ]]; then
        dep_parent=$(echo "$dep_json" | jq -r '.parent // empty')
        if [[ -n "$dep_parent" && "$task_parent" != "$dep_parent" ]]; then
          echo "ERROR: Cross-feature task dependency detected"
          echo "  Task $task_id (parent: $task_parent)"
          echo "  depends on task $dep_id (parent: $dep_parent)"
          echo "  Fix: $task_id should depend on feature $dep_parent instead"
          echo
          ((errors++)) || true
        fi
      fi
    done < <(echo "$task_json" | jq -r '.deps[]?' 2>/dev/null)
  done < <({{ tk }} query 'select(.type == "task")' 2>/dev/null)

  # Check 2: Tasks within a feature form a linear chain
  for feature_id in "${!FEATURE_CHILDREN[@]}"; do
    children=(${FEATURE_CHILDREN[$feature_id]})
    child_count=${#children[@]}

    # Skip features with 0 or 1 children — trivially linear
    if (( child_count <= 1 )); then
      continue
    fi

    # Build a map of sibling deps: task → list of sibling tasks it depends on
    declare -A SIBLING_DEP_COUNT  # task-id → count of sibling deps
    declare -A HAS_SIBLING_DEPENDENT  # task-id → true if some sibling depends on it

    for child_id in "${children[@]}"; do
      SIBLING_DEP_COUNT[$child_id]=0
      HAS_SIBLING_DEPENDENT[$child_id]=false
    done

    for child_id in "${children[@]}"; do
      child_json=$({{ tk }} query "select(.id == \"$child_id\")" 2>/dev/null)
      while IFS= read -r dep_id; do
        [[ -z "$dep_id" ]] && continue
        # Check if dep is a sibling
        for sib in "${children[@]}"; do
          if [[ "$dep_id" == "$sib" ]]; then
            SIBLING_DEP_COUNT[$child_id]=$(( ${SIBLING_DEP_COUNT[$child_id]} + 1 ))
            HAS_SIBLING_DEPENDENT[$sib]=true
          fi
        done
      done < <(echo "$child_json" | jq -r '.deps[]?' 2>/dev/null)
    done

    # Linear chain validation:
    # - Exactly one task has 0 sibling deps (first in chain)
    # - Each other task has exactly 1 sibling dep
    first_count=0
    for child_id in "${children[@]}"; do
      dep_count=${SIBLING_DEP_COUNT[$child_id]}
      if (( dep_count == 0 )); then
        ((first_count++)) || true
      elif (( dep_count > 1 )); then
        echo "ERROR: Non-linear task chain in feature $feature_id"
        echo "  Task $child_id has $dep_count sibling dependencies (expected 0 or 1)"
        echo
        ((errors++)) || true
      fi
    done
    if (( first_count != 1 )); then
      echo "ERROR: Non-linear task chain in feature $feature_id"
      echo "  Found $first_count tasks with no sibling deps (expected exactly 1)"
      echo
      ((errors++)) || true
    fi

    unset SIBLING_DEP_COUNT
    unset HAS_SIBLING_DEPENDENT
  done

  if ((errors > 0)); then
    echo "Found $errors ticket verification error(s)"
    exit 1
  fi

  echo "All tickets valid"

# Request changes on a feature after human review — reassigns to architect for rework
# If feedback is omitted, opens $EDITOR for multi-line input.
[group("human")]
request-changes feature-id feedback="":
  #!/usr/bin/env bash
  set -e
  cd "${TK_PROJECT_DIR:-{{ justfile_directory() }}}"
  feature_id="{{ feature-id }}"
  feedback="{{ feedback }}"

  # Validate feature exists
  feature_json=$({{ tk }} query "select(.id == \"$feature_id\")" 2>/dev/null)
  if [[ -z "$feature_json" ]]; then
    echo "ERROR: Feature $feature_id not found" >&2
    exit 1
  fi

  feature_type=$(echo "$feature_json" | jq -r '.type')
  if [[ "$feature_type" != "feature" ]]; then
    echo "ERROR: $feature_id is not a feature (type: $feature_type)" >&2
    exit 1
  fi

  # If no feedback provided, open editor
  if [[ -z "$feedback" ]]; then
    tmpfile=$(mktemp)
    trap 'rm -f "$tmpfile"' EXIT
    hash_char='{{ "#" }}'
    printf '\n%s %s\n%s %s\n' \
      "$hash_char" "Enter change request feedback for feature $feature_id." \
      "$hash_char" "Lines starting with $hash_char are ignored. Empty message aborts." \
      > "$tmpfile"
    editor="${EDITOR:-vi}"
    "$editor" "$tmpfile"
    feedback=$(grep -v "^$hash_char" "$tmpfile" | sed '/./,$!d' | sed -e :a -e '/^[[:space:]]*$/{ $d; N; ba; }')
  fi

  if [[ -z "$feedback" ]]; then
    echo "Aborting: empty feedback" >&2
    exit 1
  fi

  # Add human feedback note and reassign to architect
  {{ tk }} add-note "$feature_id" "[human] CHANGES REQUESTED: $feedback"
  {{ tk }} assign "$feature_id" "tk:architect-reviewer"

  echo "Feature $feature_id reassigned to architect for rework"
  echo "Run 'just start-work' — architect will determine which tasks to reopen"

# Approve a feature — validates, closes, prints next steps
[group("human")]
approve feature-id:
  #!/usr/bin/env bash
  set -e
  cd "${TK_PROJECT_DIR:-{{ justfile_directory() }}}"
  feature_id="{{ feature-id }}"

  # Validate ticket exists and is a feature
  feature_json=$({{ tk }} query "select(.id == \"$feature_id\")" 2>/dev/null)
  if [[ -z "$feature_json" ]]; then
    echo "ERROR: Ticket $feature_id not found" >&2
    exit 1
  fi
  feature_type=$(echo "$feature_json" | jq -r '.type')
  if [[ "$feature_type" != "feature" ]]; then
    echo "ERROR: $feature_id is a $feature_type, not a feature" >&2
    exit 1
  fi

  # Verify all child tasks are closed
  open_children=0
  while IFS= read -r task_json; do
    [[ -z "$task_json" ]] && continue
    task_id=$(echo "$task_json" | jq -r '.id')
    task_parent=$(echo "$task_json" | jq -r '.parent // empty')
    [[ "$task_parent" != "$feature_id" ]] && continue
    task_status=$(echo "$task_json" | jq -r '.status')
    if [[ "$task_status" != "closed" ]]; then
      echo "ERROR: Child task $task_id is still $task_status" >&2
      open_children=$((open_children + 1))
    fi
  done < <({{ tk }} query 'select(.type == "task")' 2>/dev/null)

  if (( open_children > 0 )); then
    echo "ERROR: $open_children child task(s) not closed" >&2
    exit 1
  fi

  {{ tk }} close "$feature_id"

  # Derive worktree location for display
  repo=$(just --justfile "{{ justfile() }}" --working-directory "${TK_PROJECT_DIR:-.}" resolve-repo "$feature_id")
  wt=$(just --justfile "{{ justfile() }}" --working-directory "${TK_PROJECT_DIR:-.}" worktree-name "$feature_id")
  wt_path="$repo/$wt"

  echo "Feature $feature_id approved and closed"
  echo "Worktree: $wt_path"
  echo ""
  echo "Next steps:"
  echo "  - Create PR from branch: $wt"
  echo "  - Or merge locally and run: just rebase-feature <downstream-feature>"

# Merge closed feature branches into base branch in dependency order
[group("human")]
merge-all *args:
  #!/usr/bin/env bash
  set -euo pipefail
  cd "${TK_PROJECT_DIR:-{{ justfile_directory() }}}"
  JUSTFILE="{{ justfile() }}"
  WORKING_DIR="${TK_PROJECT_DIR:-{{ justfile_directory() }}}"

  SQUASH=0
  for arg in {{ args }}; do
    case "$arg" in
      --squash) SQUASH=1 ;;
      *) echo "Unknown argument: $arg" >&2; exit 1 ;;
    esac
  done

  # --- Helpers ---

  feature_label() {
    local fid="$1" fjson="$2"
    local prefix title slug
    prefix=$(echo "$fjson" | jq -r '.["external-ref"] // empty')
    title=$({{ tk }} show "$fid" | grep '^# ' | head -1 | sed 's/^# //')
    if [[ -n "$prefix" ]]; then
      echo "$prefix: $title"
    else
      echo "$fid: $title"
    fi
  }

  resolve_local_base() {
    local base="${TK_BASE_BRANCH:-origin/HEAD}"
    if [[ "$base" == origin/* ]]; then
      # Resolve origin/HEAD → refs/remotes/origin/main → main
      local remote_ref
      if [[ "$base" == "origin/HEAD" ]]; then
        remote_ref=$(git -C "$1/default" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null || true)
      else
        remote_ref="refs/remotes/$base"
      fi
      if [[ -z "$remote_ref" ]]; then
        echo "ERROR: Could not resolve $base" >&2
        return 1
      fi
      local local_branch="${remote_ref##*/}"
      if ! git -C "$1/default" rev-parse --verify "$local_branch" &>/dev/null; then
        echo "ERROR: No local branch '$local_branch' tracking $base" >&2
        return 1
      fi
      echo "$local_branch"
    else
      echo "$base"
    fi
  }

  # --- Collect closed features with existing branches ---

  declare -A FEAT_JSON   # fid → json
  declare -A FEAT_REPO   # fid → repo dir
  declare -A FEAT_BRANCH # fid → branch name
  declare -A FEAT_DEPS   # fid → space-separated dep fids (features only)
  FEAT_ORDER=()          # topologically sorted feature IDs

  while IFS= read -r fjson; do
    [[ -z "$fjson" ]] && continue
    fid=$(echo "$fjson" | jq -r '.id')
    fstatus=$(echo "$fjson" | jq -r '.status')
    [[ "$fstatus" == "closed" ]] || continue

    repo=$(echo "$fjson" | jq -r '(.tags // [] | map(select(startswith("repo:"))) | first // ".") | ltrimstr("repo:")')
    branch=$(just --justfile "$JUSTFILE" --working-directory "$WORKING_DIR" worktree-name "$fid" 2>/dev/null || true)
    [[ -z "$branch" ]] && continue

    # Check branch exists
    if ! git -C "$repo/default" rev-parse --verify "$branch" &>/dev/null; then
      continue
    fi

    FEAT_JSON[$fid]="$fjson"
    FEAT_REPO[$fid]="$repo"
    FEAT_BRANCH[$fid]="$branch"

    # Collect feature deps (only features, not tasks)
    local deps=""
    while IFS= read -r dep_id; do
      [[ -z "$dep_id" ]] && continue
      dep_type=$({{ tk }} query "select(.id == \"$dep_id\")" 2>/dev/null | jq -r '.type' 2>/dev/null || true)
      [[ "$dep_type" == "feature" ]] && deps+="$dep_id "
    done < <(echo "$fjson" | jq -r '.deps[]?' 2>/dev/null)
    FEAT_DEPS[$fid]="${deps% }"
  done < <({{ tk }} query 'select(.type == "feature")' 2>/dev/null)

  if [[ ${#FEAT_JSON[@]} -eq 0 ]]; then
    echo "No closed features with existing branches to merge."
    exit 0
  fi

  # --- Topological sort (roots first) ---

  declare -A VISITED
  topo_visit() {
    local fid="$1"
    [[ -n "${VISITED[$fid]:-}" ]] && return
    VISITED[$fid]=1
    for dep in ${FEAT_DEPS[$fid]:-}; do
      [[ -n "${FEAT_JSON[$dep]:-}" ]] && topo_visit "$dep"
    done
    FEAT_ORDER+=("$fid")
  }

  for fid in "${!FEAT_JSON[@]}"; do
    topo_visit "$fid"
  done

  # --- Group by repo ---

  declare -A REPO_FEATURES  # repo → space-separated fids in order
  for fid in "${FEAT_ORDER[@]}"; do
    repo="${FEAT_REPO[$fid]}"
    REPO_FEATURES[$repo]+="$fid "
  done

  # --- Per-repo merge ---

  TEMP_BRANCH="_merge-all"
  declare -A ORIGINAL_SHAS     # branch → original SHA (for rollback)
  declare -A REBASED_BRANCHES  # branch → original SHA (branches we rebased, for rollback)
  MERGED_FIDS=()               # features successfully merged (across all repos)
  FAILED=0

  for repo in "${!REPO_FEATURES[@]}"; do
    local_base=$(resolve_local_base "$repo") || exit 1
    repo_dir="$repo/default"

    base_sha=$(git -C "$repo_dir" rev-parse "$local_base")
    ORIGINAL_SHAS["$repo:$local_base"]="$base_sha"

    # Create temp branch from base
    git -C "$repo_dir" branch -f "$TEMP_BRANCH" "$local_base" 2>/dev/null \
      || git -C "$repo_dir" checkout -b "$TEMP_BRANCH" "$local_base" 2>/dev/null
    git -C "$repo_dir" checkout "$TEMP_BRANCH"

    for fid in ${REPO_FEATURES[$repo]}; do
      branch="${FEAT_BRANCH[$fid]}"
      label=$(feature_label "$fid" "${FEAT_JSON[$fid]}")

      # If squash and this feature has an upstream dep that was merged this run, rebase first
      if [[ "$SQUASH" == "1" ]]; then
        for dep in ${FEAT_DEPS[$fid]:-}; do
          for merged_fid in "${MERGED_FIDS[@]:-}"; do
            if [[ "$dep" == "$merged_fid" && "${FEAT_REPO[$dep]}" == "$repo" ]]; then
              # Save original SHA for rollback
              REBASED_BRANCHES[$branch]=$(git -C "$repo_dir" rev-parse "$branch")
              echo "Rebasing $branch onto $TEMP_BRANCH (upstream $dep was squash-merged)"
              if ! git -C "$repo_dir" rebase "$TEMP_BRANCH" "$branch" 2>/dev/null; then
                echo "ERROR: Rebase failed for $branch" >&2
                git -C "$repo_dir" rebase --abort 2>/dev/null || true
                FAILED=1
                break 3
              fi
              git -C "$repo_dir" checkout "$TEMP_BRANCH"
              break 2
            fi
          done
        done
      fi

      echo "Merging $branch ($label)"
      if [[ "$SQUASH" == "1" ]]; then
        if ! git -C "$repo_dir" merge --squash "$branch" 2>/dev/null; then
          echo "ERROR: Squash merge failed for $branch ($label)" >&2
          git -C "$repo_dir" merge --abort 2>/dev/null || true
          FAILED=1
          break 2
        fi
        git -C "$repo_dir" commit -m "$label" --no-edit
      else
        if ! git -C "$repo_dir" merge --no-ff -m "$label" "$branch" 2>/dev/null; then
          echo "ERROR: Merge failed for $branch ($label)" >&2
          git -C "$repo_dir" merge --abort 2>/dev/null || true
          FAILED=1
          break 2
        fi
      fi

      MERGED_FIDS+=("$fid")
    done
  done

  # --- Rollback on failure ---

  if [[ "$FAILED" == "1" ]]; then
    echo "Aborting — rolling back all changes"
    for repo in "${!REPO_FEATURES[@]}"; do
      repo_dir="$repo/default"
      local_base=$(resolve_local_base "$repo") || true
      # Restore base branch
      git -C "$repo_dir" checkout "$local_base" 2>/dev/null || true
      git -C "$repo_dir" branch -D "$TEMP_BRANCH" 2>/dev/null || true
    done
    # Restore rebased branches
    for branch in "${!REBASED_BRANCHES[@]}"; do
      for repo in "${!REPO_FEATURES[@]}"; do
        git -C "$repo/default" branch -f "$branch" "${REBASED_BRANCHES[$branch]}" 2>/dev/null || true
      done
    done
    exit 1
  fi

  # --- Success: fast-forward base, clean up ---

  for repo in "${!REPO_FEATURES[@]}"; do
    local_base=$(resolve_local_base "$repo") || continue
    repo_dir="$repo/default"

    # Fast-forward base branch to temp
    git -C "$repo_dir" checkout "$local_base"
    git -C "$repo_dir" merge --ff-only "$TEMP_BRANCH"
    git -C "$repo_dir" branch -d "$TEMP_BRANCH"

    # Clean up merged feature worktrees and branches
    for fid in ${REPO_FEATURES[$repo]}; do
      branch="${FEAT_BRANCH[$fid]}"
      # Remove worktree if it exists
      git -C "$repo_dir" worktree remove "../$branch" 2>/dev/null || true
      # Delete branch
      git -C "$repo_dir" branch -D "$branch" 2>/dev/null || true
    done
  done

  echo ""
  echo "Merged ${#MERGED_FIDS[@]} feature(s):"
  for fid in "${MERGED_FIDS[@]}"; do
    label=$(feature_label "$fid" "${FEAT_JSON[$fid]}")
    echo "  - $label"
  done
  echo ""
  echo "Branches merged into local base. Run 'git push' when ready."

# Rebase a feature's worktree onto its correct base (lazy — run when ready to merge)
# Optional rework-notes: if provided, triggers a rework cycle after rebase (for API changes)
[group("human")]
rebase-feature feature-id rework-notes="":
  #!/usr/bin/env bash
  set -e
  cd "${TK_PROJECT_DIR:-{{ justfile_directory() }}}"
  feature_id="{{ feature-id }}"
  rework_notes="{{ rework-notes }}"

  # Validate feature exists and is a feature
  feature_json=$({{ tk }} query "select(.id == \"$feature_id\")" 2>/dev/null)
  if [[ -z "$feature_json" ]]; then
    echo "ERROR: Ticket $feature_id not found" >&2
    exit 1
  fi
  feature_type=$(echo "$feature_json" | jq -r '.type')
  if [[ "$feature_type" != "feature" ]]; then
    echo "ERROR: $feature_id is a $feature_type, not a feature" >&2
    exit 1
  fi

  # Derive repo and worktree
  repo=$(just --justfile "{{ justfile() }}" --working-directory "${TK_PROJECT_DIR:-.}" resolve-repo "$feature_id")
  wt=$(just --justfile "{{ justfile() }}" --working-directory "${TK_PROJECT_DIR:-.}" worktree-name "$feature_id")

  if [[ ! -d "$repo/$wt" ]]; then
    echo "ERROR: Worktree $repo/$wt does not exist" >&2
    exit 1
  fi

  # Determine correct new base via resolve-base-branch
  correct_base=$(just --justfile "{{ justfile() }}" --working-directory "${TK_PROJECT_DIR:-.}" resolve-base-branch "$feature_id")
  git -C "$repo/default" fetch origin >/dev/null 2>&1 || true
  correct_base_sha=$(git -C "$repo/default" rev-parse "$correct_base" 2>/dev/null)

  # No-op check: is the new base already an ancestor of HEAD?
  # If so, origin/HEAD's changes are already incorporated — nothing to rebase.
  already_up_to_date=false
  old_base=""
  if git -C "$repo/$wt" merge-base --is-ancestor "$correct_base_sha" HEAD 2>/dev/null; then
    echo "Already up to date — $correct_base is ancestor of HEAD"
    already_up_to_date=true
    if [[ -z "$rework_notes" ]]; then
      exit 0
    fi
    echo "Proceeding to trigger rework cycle..."
  fi

  if [[ "$already_up_to_date" != "true" ]]; then
    # Find fork point via Tk-Task trailers — identifies first commit belonging to this feature
    merge_base=$(git -C "$repo/$wt" merge-base "$correct_base_sha" HEAD 2>/dev/null || echo "")
    if [[ -z "$merge_base" ]]; then
      echo "ERROR: Cannot find common ancestor between $correct_base and HEAD" >&2
      exit 1
    fi

    task_ids=$({{ tk }} query "select(.parent == \"$feature_id\")" 2>/dev/null | jq -r '.id' || true)
    if [[ -z "$task_ids" ]]; then
      echo "ERROR: No tasks found for feature $feature_id" >&2
      exit 1
    fi
    grep_pattern="Tk-Task: ($(echo "$task_ids" | tr '\n' '|' | sed 's/|$//'))"
    first_own=$(git -C "$repo/$wt" log --reverse --format='%H' -E --grep="$grep_pattern" "$merge_base"..HEAD | head -1)
    if [[ -z "$first_own" ]]; then
      echo "ERROR: No commits with Tk-Task trailers found for feature $feature_id" >&2
      echo "Expected trailers matching: $grep_pattern" >&2
      exit 1
    fi
    old_base=$(git -C "$repo/$wt" rev-parse "$first_own^")

    # Rebase: replay commits after old_base onto the correct base
    echo "Rebasing $wt onto $correct_base (from $old_base)..."
  fi

  if [[ "$already_up_to_date" != "true" ]] && ! git -C "$repo/$wt" rebase --onto "$correct_base_sha" "$old_base" 2>&1; then
    echo "Rebase encountered conflicts - launching rebaser agent..."

    # Find upstream feature ID (if stacked)
    upstream_feature_id=""
    upstream_wt=""
    while IFS= read -r dep_id; do
      [[ -z "$dep_id" ]] && continue
      dep_json=$({{ tk }} query "select(.id == \"$dep_id\")" 2>/dev/null)
      [[ -z "$dep_json" ]] && continue
      dep_type=$(echo "$dep_json" | jq -r '.type')
      if [[ "$dep_type" == "feature" ]]; then
        upstream_feature_id="$dep_id"
        upstream_wt=$(just --justfile "{{ justfile() }}" --working-directory "${TK_PROJECT_DIR:-.}" worktree-name "$dep_id" 2>/dev/null || true)
        break
      fi
    done < <(echo "$feature_json" | jq -r '.deps[]?' 2>/dev/null)

    # Build rebaser prompt
    wt_abs_path="$(cd "$repo/$wt" && pwd)"
    upstream_wt_abs="none"
    if [[ -n "$upstream_wt" && -d "$repo/$upstream_wt" ]]; then
      upstream_wt_abs="$(cd "$repo/$upstream_wt" && pwd)"
    fi
    [[ -z "$upstream_feature_id" ]] && upstream_feature_id="none"

    rebaser_prompt=$(printf '%s\n\n%s\n%s\n%s\n%s\n%s\n%s' \
      "Resolve rebase conflicts." \
      "feature-id: $feature_id" \
      "upstream-feature-id: $upstream_feature_id" \
      "worktree-path: $wt_abs_path" \
      "upstream-worktree: $upstream_wt_abs" \
      "rebase-onto: $correct_base_sha" \
      "original-base: $old_base")

    # Launch rebaser synchronously
    CLAUDE="${CLAUDE_CMD}"
    [[ -z "$CLAUDE" ]] && CLAUDE='claude'
    AGENT_TIMEOUT="${TK_AGENT_TIMEOUT}"
    [[ -z "$AGENT_TIMEOUT" ]] && AGENT_TIMEOUT='1800'
    rebaser_tmpfile=$(mktemp)
    timeout --foreground "$AGENT_TIMEOUT" $CLAUDE --agent tk:rebaser --dangerously-skip-permissions \
      -p "$rebaser_prompt" 2>&1 | tee "$rebaser_tmpfile" || true
    rebaser_output=$(cat "$rebaser_tmpfile")
    rm -f "$rebaser_tmpfile"

    # Parse signal from output
    signal_type=$(echo "$rebaser_output" | tail -20 | grep -oP '^signal:\s*\K\S+' || true)

    if [[ "$signal_type" != "rebase-complete" ]]; then
      # Escalation or failure - abort rebase and print manual instructions
      git -C "$repo/$wt" rebase --abort 2>/dev/null || true
      echo "" >&2
      echo "ERROR: Rebaser could not resolve conflicts" >&2
      if [[ "$signal_type" == "escalate" ]]; then
        signal_summary=$(echo "$rebaser_output" | tail -20 | grep -oP '^summary:\s*\K.*' || true)
        echo "Reason: $signal_summary" >&2
      fi
      echo "Resolve manually:" >&2
      echo "  cd $repo/$wt" >&2
      echo "  git rebase --onto $correct_base_sha $old_base" >&2
      exit 1
    fi
    echo "Rebaser resolved conflicts successfully"
  fi

  if [[ "$already_up_to_date" != "true" ]]; then
    echo "Rebase complete"
  fi

  # If rework notes provided, trigger rework cycle for API changes
  if [[ -n "$rework_notes" ]]; then
    echo ""
    echo "Triggering rework cycle..."

    # Find upstream feature ID from deps
    upstream_feature_id=""
    while IFS= read -r dep_id; do
      [[ -z "$dep_id" ]] && continue
      dep_json=$({{ tk }} query "select(.id == \"$dep_id\")" 2>/dev/null)
      [[ -z "$dep_json" ]] && continue
      dep_type=$(echo "$dep_json" | jq -r '.type')
      if [[ "$dep_type" == "feature" ]]; then
        upstream_feature_id="$dep_id"
        break
      fi
    done < <(echo "$feature_json" | jq -r '.deps[]?' 2>/dev/null)

    # Get new commits from upstream (between old base and new base)
    # Skip if already up to date (old_base not set) or if range is invalid
    commit_shas=""
    if [[ -n "$old_base" ]]; then
      commit_shas=$(git -C "$repo/$wt" log --format="%h" "$old_base".."$correct_base_sha" 2>/dev/null | tr '\n' ', ' | sed 's/, $//')
    fi
    if [[ -z "$commit_shas" ]]; then
      commit_shas="(already incorporated)"
    fi

    # Add feature note about upstream change
    if [[ -n "$upstream_feature_id" ]]; then
      upstream_note=$(printf '[upstream-change] API change from %s (commits: %s)\n\n%s' "$upstream_feature_id" "$commit_shas" "$rework_notes")
    else
      upstream_note=$(printf '[upstream-change] API change from origin (commits: %s)\n\n%s' "$commit_shas" "$rework_notes")
    fi
    {{ tk }} add-note "$feature_id" "$upstream_note"
    echo "Added upstream-change note to feature $feature_id"

    # Reassign feature to architect for rework
    {{ tk }} assign "$feature_id" "tk:architect-reviewer"

    echo "Feature $feature_id reassigned to architect for rework"
    echo "Run 'just start-work' — architect will determine which tasks to reopen"
  fi

# --- tk pass-through commands ---

