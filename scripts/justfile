# Bundled ticket CLI
tk := ".jr/ticket/ticket"
set positional-arguments

_default:
  just --list

# List recipes in a specific group
_list-group group:
  #!/usr/bin/env bash
  group="{{ group }}"
  # Validate group exists
  if ! just --groups 2>/dev/null | grep -qxF "    $group"; then
    echo "error: Unknown group '$group'" >&2
    echo "Available groups:" >&2
    just --groups 2>&1 | tail -n +2 >&2
    exit 1
  fi
  # Filter --list output: find group header, print until next header/end
  yellow=$(tput setaf 3 2>/dev/null || true)
  bold=$(tput bold 2>/dev/null || true)
  reset=$(tput sgr0 2>/dev/null || true)
  printf 'Available recipes for [%s%s%s]:\n' "$bold$yellow" "$group" "$reset"
  just --list --unsorted --color always 2>/dev/null | awk -v g="    [$group]" '
    function strip(s) { gsub(/\033\[[0-9;]*m/, "", s); return s }
    strip($0) == g { found=1; next }
    found && strip($0) ~ /^    \[.*\]$/ { exit }
    found { print }
  '

[private]
orchestrator: (_list-group "orchestrator")
[private]
human: (_list-group "human")
[private]
plan-features: (_list-group "plan-features")
